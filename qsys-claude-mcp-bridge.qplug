-- ==============================================================================
-- Q-SYS Plugin: Claude MCP Bridge Server
-- Version: 1.0.0
-- Description: Exposes a TCP/JSON-RPC server inside Q-SYS Designer so that
--              the Claude Desktop MCP bridge can read and control the design.
-- Protocol: newline-delimited JSON-RPC 2.0 over TCP
-- ==============================================================================

PluginInfo = {
  Name         = "Claude~MCP Bridge",           -- tilde separates category from name
  Version      = "1.0.0",
  Id           = "com.qsys.claude-mcp-bridge",
  Description  = "Bidirectional MCP bridge between Q-SYS Designer and Claude Desktop AI",
  ShowDebug    = true,
  Author       = "Q-SYS Claude Integration",
  Contact      = ""
}

-- ==============================================================================
-- DESIGN-TIME: Properties
-- ==============================================================================
function GetProperties()
  return {
    {
      Name    = "TCP Port",
      Type    = "integer",
      Value   = 8765,
      Min     = 1024,
      Max     = 65535
    },
    {
      Name    = "Max Clients",
      Type    = "integer",
      Value   = 4,
      Min     = 1,
      Max     = 16
    },
    {
      Name    = "Heartbeat Interval (sec)",
      Type    = "integer",
      Value   = 30,
      Min     = 5,
      Max     = 300
    },
    {
      Name    = "Allow Control Writes",
      Type    = "boolean",
      Value   = true
    }
  }
end

-- ==============================================================================
-- DESIGN-TIME: Controls
-- ==============================================================================
function GetControls(props)
  return {
    -- Status indicators
    { Name = "Status",           ControlType = "Indicator", IndicatorType = "Status", UserPin = true,  PinStyle = "Output"     },
    { Name = "StatusText",       ControlType = "Indicator", IndicatorType = "Text",   UserPin = true,  PinStyle = "Output"     },
    { Name = "ConnectedClients", ControlType = "Indicator", IndicatorType = "Text",   UserPin = true,  PinStyle = "Output"     },
    { Name = "BytesReceived",    ControlType = "Indicator", IndicatorType = "Text",   UserPin = false                         },
    { Name = "CommandCount",     ControlType = "Indicator", IndicatorType = "Text",   UserPin = false                         },
    -- Controls
    { Name = "Restart",          ControlType = "Button",    ButtonType    = "Trigger",UserPin = true,  PinStyle = "Input"      },
    { Name = "ClearLog",         ControlType = "Button",    ButtonType    = "Trigger",UserPin = false                         },
    -- Log
    { Name = "EventLog",         ControlType = "Indicator", IndicatorType = "Text",   UserPin = false                         }
  }
end

-- ==============================================================================
-- DESIGN-TIME: Pages
-- ==============================================================================
function GetPages(props)
  return {
    { name = "Server" },
    { name = "About"  }
  }
end

-- ==============================================================================
-- DESIGN-TIME: Pins (external I/O)
-- ==============================================================================
function GetPins(props)
  return {}
end

