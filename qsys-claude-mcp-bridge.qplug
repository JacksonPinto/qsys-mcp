  local W, H     = 440, 280

  -- ── Background ──────────────────────────────────────────────────────────────
  table.insert(graphics, {
    Type        = "GroupBox",
    Text        = "Claude MCP Bridge Server  v1.0.0",
    Fill        = { R = 15,  G = 18,  B = 30  },
    StrokeColor = { R = 80,  G = 130, B = 255 },
    StrokeWidth = 2,
    CornerRadius= 6,
    Position    = { 0, 0 },
    Size        = { W, H },
    FontSize    = 11,
    Color       = { R = 180, G = 200, B = 255 }
  })

  -- ── Status row ──────────────────────────────────────────────────────────────
  layout["Status"] = {
    PrettyName = "Server Status",
    Style      = "StatusLight",
    Position   = { 12, 32 },
    Size       = { 20, 20 }
  }
  layout["StatusText"] = {
    PrettyName = "Status Text",
    Style      = "Text",
    Position   = { 36, 32 },
    Size       = { W - 50, 20 },
    HTextAlign = "Left",
    Color      = { R = 220, G = 225, B = 255 }
  }

  -- ── Client count ────────────────────────────────────────────────────────────
